# ═══ JARVIS — конфигурация окружения ═══
# Переименуй в .env и заполни значения

# Модель и профиль по умолчанию
JARVIS_DEFAULT_MODEL=qwen3:8b
JARVIS_DEFAULT_PROFILE=Универсальный

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434

# Пути данных (относительно backend/)
JARVIS_DATA_DIR=data
JARVIS_UPLOAD_DIR=data/uploads
JARVIS_GENERATED_DIR=data/generated
JARVIS_PLUGINS_DIR=data/plugins

# Генерация картинок
IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
IMAGE_MAX_PIXELS=1048576

# Сервер
JARVIS_HOST=127.0.0.1
JARVIS_PORT=8000
JARVIS_RELOAD=true
